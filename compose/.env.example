# Copy to .env and fill in PUBLIC_ENTRY + ACME_EMAIL.
# Or run `make wizard` from the repo root, which writes .env for you.
#
# WORKSPACE, XOR_KEY, and ADMIN_PASSWORD are auto-generated by
# scripts/init-config.sh on first `make platform-up` and persisted
# back to this file. DO NOT pre-fill them.

PUBLIC_ENTRY=ctf.example.com
ACME_EMAIL=admin@ctf.example.com
