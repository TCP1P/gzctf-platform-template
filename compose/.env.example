# Copy to .env and fill in PUBLIC_ENTRY + ACME_EMAIL.
# Or run `make wizard` from the repo root, which writes .env for you.
#
# WORKSPACE, XOR_KEY, ADMIN_PASSWORD, POSTGRES_PASSWORD, and
# AD_SSH_INTERNAL_SECRET are auto-generated by scripts/init-config.sh on first
# `make platform-up` and persisted back to this file. DO NOT pre-fill them.

PUBLIC_ENTRY=ctf.example.com
ACME_EMAIL=admin@ctf.example.com

# A&D SSH jump host (optional). Players SSH to PUBLIC_ENTRY on this port to reach
# their own challenge container: `ssh <challenge-id>@PUBLIC_ENTRY -p 22022`.
# AD_SSH_INTERNAL_SECRET is auto-generated (see above) — do NOT set it by hand.
# Override the host port only if 22022 clashes with something on the host:
# AD_SSH_PUBLIC_PORT=22022
